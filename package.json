{
  "name": "cosystem",
  "version": "0.0.0",
  "private": true,
  "description": "CoSystem - The meta-framework for coexisting UI frameworks.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coactionjs/cosystem.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run test:create-runtime && pnpm run test:scaffold-install && pnpm run test:core:decorators-install && pnpm run test:core:container-install && pnpm run test:core:app-providers-install && pnpm run test:core:plugin-providers-install && pnpm run test:core:lifecycle-install && pnpm run test:core:async-lazy-install && pnpm run test:core:logger-install && pnpm run test:core:actions-install && pnpm run test:examples && pnpm run test:examples:install && pnpm run test:examples:testing-install && pnpm run test:testing:install-runtime && pnpm run test:svelte:install-runtime && pnpm run test:frameworks:install && pnpm run test:frameworks:react-browser && pnpm run test:frameworks:vue-browser && pnpm run test:frameworks:solid-browser && pnpm run test:frameworks:worker-install && pnpm run test:examples:runtime && pnpm run test:router:memory-install && pnpm run test:router-browser && pnpm run test:storage:like-install && pnpm run test:storage:service-install && pnpm run test:storage-browser && pnpm run test:storage:indexeddb-browser && pnpm run test:devtools-browser && pnpm run test:plugins:browser && pnpm run test:worker:install-runtime && pnpm run test:worker:async-browser && pnpm run test:worker:state-conflict-install && pnpm run test:worker:broadcast-browser && pnpm run test:worker:data-transport-install && pnpm run test:exports && pnpm run test:pack && pnpm run test:install && pnpm run test:publish-dry-run",
    "ci": "pnpm run check",
    "clean": "turbo run clean && rm -rf node_modules .turbo coverage",
    "commit": "cz",
    "dev": "turbo run dev --parallel",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "husky",
    "publish:packages": "node scripts/publish-packages.mjs",
    "release": "pnpm run build && pnpm run publish:packages",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:core:actions-install": "node scripts/installed-core-actions-smoke.mjs",
    "test:core:app-providers-install": "node scripts/installed-core-app-providers-smoke.mjs",
    "test:core:async-lazy-install": "node scripts/installed-core-async-lazy-smoke.mjs",
    "test:core:container-install": "node scripts/installed-core-container-smoke.mjs",
    "test:core:decorators-install": "node scripts/installed-core-decorators-smoke.mjs",
    "test:core:lifecycle-install": "node scripts/installed-core-lifecycle-scope-smoke.mjs",
    "test:core:logger-install": "node scripts/installed-core-logger-plugin-smoke.mjs",
    "test:core:plugin-providers-install": "node scripts/installed-core-plugin-providers-smoke.mjs",
    "test:create-runtime": "node scripts/create-project-runtime-smoke.mjs",
    "test:examples": "node scripts/example-build-smoke.mjs",
    "test:examples:install": "node scripts/installed-example-build-smoke.mjs",
    "test:examples:testing-install": "node scripts/installed-testing-example-smoke.mjs",
    "test:examples:runtime": "node scripts/example-runtime-smoke.mjs",
    "test:devtools-browser": "node scripts/installed-devtools-browser-smoke.mjs",
    "test:exports": "node scripts/package-exports-smoke.mjs",
    "test:frameworks:install": "node scripts/installed-framework-adapters-smoke.mjs",
    "test:frameworks:react-browser": "node scripts/installed-react-browser-smoke.mjs",
    "test:frameworks:solid-browser": "node scripts/installed-solid-browser-smoke.mjs",
    "test:frameworks:vue-browser": "node scripts/installed-vue-browser-smoke.mjs",
    "test:frameworks:worker-install": "node scripts/installed-framework-worker-adapters-smoke.mjs",
    "test:install": "node scripts/package-install-smoke.mjs",
    "test:pack": "node scripts/package-pack-smoke.mjs",
    "test:plugins:browser": "node scripts/installed-plugin-stack-browser-smoke.mjs",
    "test:publish-dry-run": "node scripts/publish-dry-run-smoke.mjs",
    "test:router:memory-install": "node scripts/installed-router-memory-smoke.mjs",
    "test:router-browser": "node scripts/installed-router-browser-smoke.mjs",
    "test:scaffold-install": "node scripts/scaffold-install-smoke.mjs",
    "test:storage:like-install": "node scripts/installed-storage-like-plugin-smoke.mjs",
    "test:storage:service-install": "node scripts/installed-storage-service-smoke.mjs",
    "test:storage-browser": "node scripts/storage-browser-smoke.mjs",
    "test:storage:indexeddb-browser": "node scripts/installed-storage-indexeddb-browser-smoke.mjs",
    "test:svelte:install-runtime": "node scripts/installed-svelte-runtime-smoke.mjs",
    "test:testing:install-runtime": "node scripts/installed-testing-helper-smoke.mjs",
    "test:worker:async-browser": "node scripts/installed-worker-async-browser-smoke.mjs",
    "test:worker:broadcast-browser": "node scripts/installed-broadcast-worker-browser-smoke.mjs",
    "test:worker:data-transport-install": "node scripts/installed-data-transport-worker-smoke.mjs",
    "test:worker:install-runtime": "node scripts/installed-worker-runtime-smoke.mjs",
    "test:worker:state-conflict-install": "node scripts/installed-worker-state-conflict-smoke.mjs",
    "test:turbo": "turbo run test",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "commitizen": "catalog:",
    "cz-git": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "rolldown": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,graphql,html,json,jsonc,json5,md,mdx,yaml,yml}": [
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.8.0"
  },
  "packageManager": "pnpm@11.8.0"
}
