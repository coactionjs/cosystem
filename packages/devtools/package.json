{
  "name": "@cosystem/devtools",
  "version": "0.1.1",
  "description": "Dev inspection plugin for CoSystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coactionjs/cosystem.git",
    "directory": "packages/devtools"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf coverage dist .turbo",
    "dev": "tsdown --watch",
    "test": "cd ../.. && vitest run --project @cosystem/devtools",
    "test:coverage": "cd ../.. && vitest run --coverage --project @cosystem/devtools",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cosystem/core": "workspace:*"
  },
  "devDependencies": {
    "@cosystem/tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
